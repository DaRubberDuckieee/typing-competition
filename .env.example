# Copy to .env.local for local dev, or set these in Vercel's dashboard.

# Supabase project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — used by the browser for Realtime subscriptions.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — used by API routes (server-only). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Random secret for admin endpoints. Staff paste this into the Admin page once.
ADMIN_TOKEN=
